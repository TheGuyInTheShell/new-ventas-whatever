        "rollup-plugin-postcss": "^4.0.2",
        "tailwindcss": "^3.1.4",
        "tailwindcss-animated": "^1.1.0"
    },
    "dependencies": {
        "alpinejs": "^3.15.2",
        "apexcharts": "^3.49.1",
        "htmx.org": "^2.0.8",
