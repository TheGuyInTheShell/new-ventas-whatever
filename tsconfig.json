{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "allowJs": true,
    "noEmit": true,
    "paths": {
      "@/*": [
        "./src/app/assets/ts/*"
      ]
    },
    "lib": [
      "ESNext",
      "DOM",
      "DOM.Iterable"
    ]
  },
  "include": [
    "src/app/assets/ts/**/*",
    "rolldown.config.mjs"
  ],
  "exclude": [
    "node_modules"
  ]
}